# AquaPulse Environment Variables
# Copy this file to .env and fill in real values before production builds.

# --- AdMob (Build-time: used in app.config.ts for native plugin config) ---
ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY

# --- AdMob Ad Unit IDs (Runtime: used in lib/ads.ts) ---
# Falls back to Google test IDs if unset.
EXPO_PUBLIC_ADMOB_IOS_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY

# --- RevenueCat (Runtime: used in lib/purchases.ts) ---
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_XXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_XXXXXXXXXXXXXXXXXX

# --- EAS (Build-time: used in app.config.ts) ---
EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID
